# ==========================================
# 后端环境变量示例文件（请复制为 .env 或 .env.production）
# ==========================================

# 运行环境：development / production
GO_ENV=development
GIN_MODE=debug

# HTTP 服务配置
HOST=127.0.0.1
PORT=8080

# 站点/接口基础地址（用于生成链接、SEO等场景）
SITE_URL=http://localhost:3000
BASE_URL=http://127.0.0.1:8080

# JWT 配置（务必在生产环境替换为强随机值）
JWT_SECRET=please-change-me-in-production

# 后台配置加密密钥（用于加密存储 Cloudflare Global API Key 等敏感配置）
# 必须为 32 字节：可以直接填 32 位随机字符串，或填 base64/hex（解码后 32 bytes）
# 生成示例：openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=

# 邮件后台支持 SMTP / Resend / 阿里邮箱 API 开放平台。
# 阿里邮箱 AppID/Secret 建议在后台「邮件」页面保存，不要写死到代码。
# 如使用阿里邮箱 API，请确保应用已开启 Mail.Send.All 权限；
# 如开启“限制仅以下 IP 可调用”，需把后端服务器出口 IP 加入白名单。

# 图库上传图片压缩（服务端）
# MEDIA_MAX_DIM: 最大边长（像素），会等比缩放，默认 1600
# MEDIA_JPEG_QUALITY: JPEG 质量 1-100，默认 82
# MEDIA_PNG_COMPRESSION: PNG 压缩级别 0-3，默认 2
MEDIA_MAX_DIM=1600
MEDIA_JPEG_QUALITY=82
MEDIA_PNG_COMPRESSION=2

JWT_EXPIRES_HOURS=24
CUSTOMER_JWT_EXPIRES_HOURS=168

# 默认管理员账号（安全开关）
# - 生产环境建议：设置 SEED_DEFAULT_ADMIN=true + DEFAULT_ADMIN_PASSWORD，并在首次启动后关闭开关或保管好密码
# - 开发环境：不设置 SEED_DEFAULT_ADMIN 时默认会创建（密码兜底为 admin123）
SEED_DEFAULT_ADMIN=
RESET_DEFAULT_ADMIN_PASSWORD=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@vibocnc.com
DEFAULT_ADMIN_FULLNAME=System Administrator
DEFAULT_ADMIN_ROLE=admin
DEFAULT_ADMIN_PASSWORD=

# 数据库配置（MySQL）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=fanuc_sales

# 是否自动迁移（生产环境建议配合备份谨慎开启）
DB_AUTO_MIGRATE=true

# CORS（可选，默认使用代码里的宽松策略）
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
# CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_HEADERS=Authorization,Content-Type

# 上传目录（可选，默认由代码或容器映射决定）
# UPLOAD_PATH=./uploads

# 列表分页（可选）
# MAX_PAGE_SIZE=100

# ==========================================
# ISR Revalidation (Next.js on-demand revalidation)
# ==========================================
# Frontend URL for triggering ISR revalidation
FRONTEND_URL=http://localhost:3000
# Must match REVALIDATE_SECRET in frontend .env
REVALIDATE_SECRET=your-revalidate-secret-here
